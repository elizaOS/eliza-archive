{
  "name": "@elizaos/plugin-omnivoice",
  "version": "2.0.3-beta.14",
  "type": "module",
  "main": "dist/node/index.node.js",
  "module": "dist/node/index.node.js",
  "types": "dist/index.d.ts",
  "browser": "dist/browser/index.browser.js",
  "sideEffects": false,
  "description": "Local TTS via omnivoice.cpp (k2-fsa OmniVoice) — voice cloning, voice design, and emotion-aware synthesis on CPU/Metal/CUDA/Vulkan.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.node.ts",
        "import": "./src/index.node.ts",
        "default": "./src/index.node.ts"
      },
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "import": "./dist/browser/index.browser.js",
        "default": "./dist/browser/index.browser.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.node.js",
        "default": "./dist/node/index.node.js"
      },
      "default": "./dist/node/index.node.js"
    }
  },
  "files": [
    "dist",
    "auto-enable.ts"
  ],
  "elizaos": {
    "plugin": {
      "autoEnableModule": "./auto-enable.ts",
      "capabilities": [
        "text-to-speech",
        "voice-cloning",
        "voice-design",
        "emotion-aware-tts",
        "singing"
      ]
    }
  },
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.2.22",
    "@types/node": "^24.5.2",
    "bun-types": "1.3.14",
    "typescript": "^6.0.3",
    "vitest": "^4.0.17"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot build.ts",
    "test": "vitest run --config ./vitest.config.ts",
    "clean": "rm -rf dist .turbo .turbo-tsconfig.json tsconfig.tsbuildinfo",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "tsgo --noEmit --rootDir ../.."
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "OMNIVOICE_LIB_PATH": {
        "type": "string",
        "description": "Absolute path to libomnivoice.{so,dylib,dll}. Built via packages/inference/build-omnivoice.mjs.",
        "required": false,
        "sensitive": false
      },
      "OMNIVOICE_MODEL_PATH": {
        "type": "string",
        "description": "Path to the omnivoice base LM GGUF (e.g. omnivoice-base-Q8_0.gguf).",
        "required": true,
        "sensitive": false
      },
      "OMNIVOICE_CODEC_PATH": {
        "type": "string",
        "description": "Path to the omnivoice tokenizer/codec GGUF (e.g. omnivoice-tokenizer-Q8_0.gguf).",
        "required": true,
        "sensitive": false
      },
      "OMNIVOICE_SINGING_MODEL_PATH": {
        "type": "string",
        "description": "Optional ModelsLab/omnivoice-singing GGUF for the singing codepath.",
        "required": false,
        "sensitive": false
      },
      "OMNIVOICE_LANG": {
        "type": "string",
        "description": "Default language hint passed to ov_tts_params.lang. \"\" = auto.",
        "required": false,
        "default": "English",
        "sensitive": false
      },
      "OMNIVOICE_INSTRUCT": {
        "type": "string",
        "description": "Default voice-design instruct string (e.g. \"female young adult moderate happy\").",
        "required": false,
        "sensitive": false
      },
      "OMNIVOICE_USE_FA": {
        "type": "boolean",
        "description": "Enable flash attention for the GPU backend.",
        "required": false,
        "default": "true",
        "sensitive": false
      }
    }
  },
  "eliza": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Node/Bun build, requires libomnivoice shared library at runtime."
    }
  }
}
