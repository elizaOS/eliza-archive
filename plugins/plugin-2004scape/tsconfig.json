{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "@elizaos/agent": [
        "../../packages/agent/dist/packages/agent/src/index.d.ts"
      ],
      "@elizaos/agent/services/app-session-gate": [
        "../../packages/agent/src/services/app-session-gate.d.ts"
      ],
      "@elizaos/app-core": ["../../packages/app-core/dist/index.d.ts"],
      "@elizaos/core": ["../../packages/core/dist/index.d.ts"],
      "@elizaos/shared": ["../../packages/shared/dist/index.d.ts"],
      "react": ["../../packages/app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "../../packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "lucide-react": ["../plugin-companion/node_modules/lucide-react"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/agent/src/external-modules.d.ts",
    "../../packages/app-core/src/ambient-modules.d.ts"
  ],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
