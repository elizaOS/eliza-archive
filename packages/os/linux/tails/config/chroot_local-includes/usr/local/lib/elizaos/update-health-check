#!/bin/sh

set -eu

run_dir=/run/elizaos
selection="${run_dir}/runtime-selection.json"
timeout="${ELIZAOS_UPDATE_HEALTH_TIMEOUT:-240}"
mark_bad_on_timeout="${ELIZAOS_UPDATE_HEALTH_MARK_BAD_ON_TIMEOUT:-0}"

log() {
    printf 'elizaos-update-health-check: %s\n' "$*" >&2
}

if [ "$(id -u)" -ne 0 ]; then
    log "must run as root"
    exit 77
fi

[ -r "${selection}" ] || exit 0

selection_status="$(
    python3 - "${selection}" <<'PY' 2>/dev/null || true
import json
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    selection = json.load(handle)
print(selection.get("trust", ""))
print(selection.get("status", ""))
PY
)"

trust="$(printf '%s\n' "${selection_status}" | sed -n '1p')"
status="$(printf '%s\n' "${selection_status}" | sed -n '2p')"

if [ "${trust}" != "signed" ] || [ "${status}" != "candidate" ]; then
    exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
    log "curl unavailable; leaving candidate unpromoted"
    exit 0
fi

deadline=$(( $(date +%s) + timeout ))
while [ "$(date +%s)" -le "${deadline}" ]; do
    if curl --noproxy '*' -fsS http://127.0.0.1:31337/api/auth/status >/dev/null 2>&1 \
        && curl --noproxy '*' -fsS http://127.0.0.1:5174/api/health >/dev/null 2>&1
    then
        /usr/local/lib/elizaos/update-manager mark-good
        log "candidate runtime promoted"
        exit 0
    fi
    sleep 2
done

if [ "${mark_bad_on_timeout}" = "1" ]; then
    /usr/local/lib/elizaos/update-manager mark-bad
    log "candidate runtime rejected after health timeout"
    exit 0
fi

log "candidate runtime did not pass health before timeout; leaving unpromoted"
exit 75
