#!/bin/sh

set -eu

if [ "$(id -u)" -eq 0 ]; then
    echo "elizaOS renderer must run as the live user, not as root." >&2
    exit 1
fi

if [ "$(id -un)" != "amnesia" ]; then
    echo "elizaOS renderer must run as the Tails live user 'amnesia'." >&2
    exit 1
fi

if [ -x /usr/local/lib/elizaos/persistence-maintenance ]; then
    /usr/local/lib/elizaos/persistence-maintenance wait
fi

if [ -r /usr/local/lib/elizaos/runtime-env ]; then
    . /usr/local/lib/elizaos/runtime-env
fi
ELIZAOS_RUNTIME_ROOT="${ELIZAOS_RUNTIME_ROOT:-${ELIZAOS_RUNTIME_DIR:-/opt/milady}}"
ELIZAOS_BUN="${ELIZAOS_BUN:-${ELIZAOS_RUNTIME_ROOT}/bin/bun}"

if [ ! -x "${ELIZAOS_BUN}" ]; then
    echo "elizaOS Bun runtime is not installed at ${ELIZAOS_BUN}." >&2
    exit 1
fi

if [ ! -f /usr/local/lib/elizaos/renderer-server.mjs ]; then
    echo "elizaOS renderer server is not installed." >&2
    exit 1
fi

export HOME=/home/amnesia
export PATH="${ELIZAOS_RUNTIME_ROOT}/bin:${PATH}"
export ELIZA_STATE_DIR="${ELIZA_STATE_DIR:-/home/amnesia/.eliza}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${ELIZA_STATE_DIR}/xdg-config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${ELIZA_STATE_DIR}/xdg-cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${ELIZA_STATE_DIR}/xdg-data}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-${ELIZA_STATE_DIR}/xdg-state}"
export ELIZA_API_PORT="${ELIZA_API_PORT:-31337}"
export ELIZAOS_RENDERER_PORT="${ELIZAOS_RENDERER_PORT:-5174}"
export ELIZAOS_RENDERER_HOST=127.0.0.1
export ELIZAOS_RENDERER_ROOT="${ELIZAOS_RENDERER_ROOT:-${ELIZAOS_RUNTIME_ROOT}/Resources/app/renderer}"
export ELIZA_DESKTOP_API_BASE="http://127.0.0.1:${ELIZA_API_PORT}"
export ELIZA_API_BASE="${ELIZA_DESKTOP_API_BASE}"

mkdir -p \
    "${ELIZA_STATE_DIR}" \
    "${ELIZA_STATE_DIR}/logs" \
    "${XDG_CONFIG_HOME}" \
    "${XDG_CACHE_HOME}" \
    "${XDG_DATA_HOME}" \
    "${XDG_STATE_HOME}"

unset LD_PRELOAD

exec "${ELIZAOS_BUN}" /usr/local/lib/elizaos/renderer-server.mjs
