#!/bin/sh

set -eu

run_dir=/run/elizaos
flag="${run_dir}/persistence-maintenance"
runtime_dir=/run/user/1000
user_persistence_flag="${runtime_dir}/elizaos-persistence-setup"
bus="unix:path=${runtime_dir}/bus"

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "persistence-maintenance ${1} must run as root." >&2
        exit 77
    fi
}

user_systemctl() {
    [ -S "${runtime_dir}/bus" ] || return 0
    runuser -u amnesia -- env \
        HOME=/home/amnesia \
        XDG_RUNTIME_DIR="${runtime_dir}" \
        DBUS_SESSION_BUS_ADDRESS="${bus}" \
        systemctl --user "$@" >/dev/null 2>&1 || true
}

kill_elizaos_processes() {
    user_systemctl kill --kill-whom=all --signal=TERM \
        elizaos-agent.service \
        elizaos-renderer.service \
        milady.service
    sleep 2
    user_systemctl kill --kill-whom=all --signal=KILL \
        elizaos-agent.service \
        elizaos-renderer.service \
        milady.service
}

start_elizaos_units() {
    user_systemctl reset-failed \
        elizaos-agent.service \
        elizaos-renderer.service \
        milady.service
    user_systemctl start --no-block elizaos-agent.service
    user_systemctl start --no-block elizaos-renderer.service
    user_systemctl start --no-block milady.service
}

case "${1:-}" in
    enter)
        require_root enter
        install -d -o root -g root -m 0755 "${run_dir}"
        printf 'persistent-storage\n' > "${flag}"
        chown root:root "${flag}"
        chmod 0644 "${flag}"
        kill_elizaos_processes
        ;;
    leave)
        require_root leave
        rm -f -- "${flag}"
        start_elizaos_units
        ;;
    wait)
        while [ -e "${flag}" ] || [ -e "${user_persistence_flag}" ]; do
            sleep 1
        done
        ;;
    *)
        echo "usage: persistence-maintenance enter|leave|wait" >&2
        exit 64
        ;;
esac
