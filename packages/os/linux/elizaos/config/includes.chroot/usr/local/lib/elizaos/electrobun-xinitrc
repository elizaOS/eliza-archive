#!/bin/sh
# xinit client for the elizaOS kiosk: set the kiosk environment, then exec the
# Electrobun app fullscreen on the Xorg session that xinit just started. No
# window manager — the app's GTK window IS the locked single-app kiosk.
set -eu

export ELIZAOS_SHELL_MODE=kiosk
export ELIZAOS_AGENT_URL=http://127.0.0.1:31337

# QEMU/headless GPUs have no hardware GL; force Mesa software (llvmpipe) and
# disable WebKit's GL/dmabuf renderer so WebKitGTK paints in software instead
# of a black GLX surface. Harmless on real GPUs.
export LIBGL_ALWAYS_SOFTWARE=1
export GALLIUM_DRIVER=llvmpipe
export WEBKIT_DISABLE_DMABUF_RENDERER=1
export WEBKIT_DISABLE_COMPOSITING_MODE=1

# Disable WebKitGTK's bubblewrap sandbox. WebKit2GTK spawns its content
# WebKitWebProcess inside a bwrap sandbox that needs unprivileged user
# namespaces; under the live appliance running as `user` with restricted
# userns, bwrap can fail to create the namespace and the WebProcess never
# spawns. Safe here: the whole device is a locked single-app appliance.
export WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1

# Skip Electrobun's WebGPU/Dawn init in the bun Worker. libwebgpu_dawn.so static
# initializers + the Vulkan loader's ICD enumeration wedge the Worker thread at
# top-level `await init_bun()` inside QEMU (no real Vulkan ICD, virtio-gpu render
# node probing stalls), which leaves the GTK main thread sitting in poll() with
# no dispatched FFI callbacks — externally indistinguishable from a wrapper
# deadlock. Electrobun's findWgpuLibraryPath() honors ELECTROBUN_WGPU_PATH; a
# non-existent path makes init_webGPU skip the dlopen entirely. The kiosk has no
# need for WebGPU — WebKitGTK renders the UI. VK_LOADER_DRIVERS_DISABLE belt-
# and-suspenders nukes any residual Vulkan ICD discovery.
export ELECTROBUN_WGPU_PATH=/nonexistent
export VK_LOADER_DRIVERS_DISABLE=*

exec /opt/elizaos/app/elizaos --shell-mode=kiosk
