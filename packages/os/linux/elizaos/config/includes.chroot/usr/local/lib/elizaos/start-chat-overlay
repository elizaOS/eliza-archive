#!/bin/sh
# Start the elizaOS chat overlay — a floating, always-on, global chat
# surface bound to the local agent. Same Electrobun bundle as the
# launcher, dispatched via --shell-mode=chat-overlay.
#
# The overlay is an Electrobun-only surface: it relies on a borderless,
# always-on-top native window that the WebKitGTK kiosk fallback cannot
# provide. On arches without the Electrobun prebuild (riscv64), the
# launcher's fullscreen kiosk already presents the full home view
# (including chat), so there is no separate overlay to start.
set -eu

AGENT_URL="${ELIZAOS_AGENT_URL:-http://127.0.0.1:31337}"

if [ ! -x /opt/elizaos/app/elizaos ]; then
    echo "elizaos: Electrobun binary absent; chat overlay served by launcher kiosk." >&2
    exit 0
fi

for _ in $(seq 1 60); do
    if curl -fsS "${AGENT_URL}/api/health" >/dev/null 2>&1; then
        break
    fi
    sleep 1
done

exec /opt/elizaos/app/elizaos --shell-mode=chat-overlay
