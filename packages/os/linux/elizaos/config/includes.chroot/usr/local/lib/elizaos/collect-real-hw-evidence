#!/bin/sh
# elizaOS — real-hardware evidence collector.
#
# Purpose: on real hardware we cannot capture QEMU serial / VNC. Instead, the
# user provisions a second FAT partition on the live USB labeled
# "ELIZAOS-EVIDENCE" (after `dd`-flashing the ISO). At boot we look for that
# partition; if present we mount it RW and dump:
#   - kiosk-NNN.png   (Xorg screenshot via scrot, every 30s, up to 10 shots)
#   - journal.log     (full journal at capture time)
#   - dmesg.log       (kernel ring buffer)
#   - env.txt         (DRM driver, Xorg log, xrandr, kiosk env)
#
# The script no-ops silently if no labeled partition exists, so the kiosk is
# unaffected on machines the user did not prep. It exits after the capture
# window so it never holds the USB stick.
set -eu

LABEL="ELIZAOS-EVIDENCE"
MNT="/run/elizaos-evidence"
LOG_TAG="elizaos-evidence"

log() { echo "${LOG_TAG}: $*" >&2; }

# Resolve the partition by FS label. blkid returns the device node or empty.
DEV="$(blkid -L "${LABEL}" 2>/dev/null || true)"
if [ -z "${DEV}" ]; then
    log "no partition labeled ${LABEL} found; skipping evidence capture"
    exit 0
fi
log "found ${LABEL} at ${DEV}; mounting at ${MNT}"

mkdir -p "${MNT}"
# vfat is the expected format; fail loud if the user formatted as something
# else and we cannot mount it (don't hide the failure).
mount -t vfat -o rw,uid=0,gid=0,umask=0022 "${DEV}" "${MNT}"

STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
SESSION="${MNT}/${STAMP}"
mkdir -p "${SESSION}"
log "writing into ${SESSION}"

# Environment / driver fingerprint (one-shot, immediately).
{
    echo "# elizaOS real-hw evidence ${STAMP}"
    echo "## uname"
    uname -a
    echo
    echo "## /proc/cmdline"
    cat /proc/cmdline
    echo
    echo "## drm driver"
    for d in /sys/class/drm/card*/device/driver; do
        [ -e "$d" ] || continue
        printf '%s -> %s\n' "$d" "$(readlink -f "$d")"
    done
    echo
    echo "## /dev/dri"
    ls -la /dev/dri 2>&1 || true
    echo
    echo "## lspci -nnk (gpu)"
    lspci -nnk 2>/dev/null | grep -A3 -iE 'vga|3d|display' || true
} > "${SESSION}/env.txt" 2>&1

# Kernel ring buffer.
dmesg > "${SESSION}/dmesg.log" 2>&1 || true

# Wait for the Xorg session owned by `user` to come up, then capture
# screenshots into the partition. The Electrobun kiosk runs on :0 (vt1) as
# user `user`; xinit creates /tmp/.X11-unix/X0 when ready.
i=0
while [ $i -lt 30 ]; do
    if [ -S /tmp/.X11-unix/X0 ]; then
        break
    fi
    i=$((i + 1))
    sleep 1
done

if [ ! -S /tmp/.X11-unix/X0 ]; then
    log "X0 socket never appeared after 30s; kiosk likely failed to start"
    journalctl --no-pager -b > "${SESSION}/journal.log" 2>&1 || true
    sync
    umount "${MNT}" || true
    exit 0
fi

# Capture 10 screenshots, 30s apart (5-minute window). scrot must run as the
# Xorg display owner; allow root by exporting XAUTHORITY for `user`.
XAUTH="$(ls /home/user/.Xauthority 2>/dev/null || true)"
if [ -z "${XAUTH}" ]; then
    # xinit writes the cookie file the user's homedir; if it is absent fall
    # back to running scrot as the user.
    XAUTH=""
fi

n=0
while [ $n -lt 10 ]; do
    OUT="${SESSION}/kiosk-$(printf '%02d' "$n").png"
    if [ -n "${XAUTH}" ]; then
        DISPLAY=:0 XAUTHORITY="${XAUTH}" scrot --silent "${OUT}" >/dev/null 2>&1 || \
            log "scrot failed at n=$n (XAUTH=${XAUTH})"
    else
        sudo -u user DISPLAY=:0 scrot --silent "${OUT}" >/dev/null 2>&1 || \
            log "scrot (sudo -u user) failed at n=$n"
    fi
    # Refresh journal each round so a late crash is still captured.
    journalctl --no-pager -b > "${SESSION}/journal.log" 2>&1 || true
    sync
    n=$((n + 1))
    sleep 30
done

log "capture window complete; unmounting ${MNT}"
umount "${MNT}" || true
