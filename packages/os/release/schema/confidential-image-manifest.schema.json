{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elizaos.ai/schemas/confidential-image-manifest.v1.json",
  "title": "ElizaOS confidential image manifest",
  "description": "The 'image is the policy' contract (plan §1.3/§2.2, OS-1; shared with chip 06 §2.2 / WI-3). Records every measured component digest (kernel/initrd/rootfs/app-compose) plus the exact build inputs (toolchain SHAs, layer commits) so a verifier rebuilds offline and asserts digest equality. The same schema serves the TDX/meta-dstack and the riscv64/CoVE image builders.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedBy",
    "summary",
    "image",
    "components",
    "buildInputs",
    "measurements",
    "reproducibility",
    "gate"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedBy": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "substrate", "builder", "architecture"],
      "properties": {
        "profile": { "const": "confidential" },
        "substrate": { "enum": ["tdx", "cove"] },
        "builder": { "enum": ["meta-dstack", "buildroot-elizaos"] },
        "architecture": { "enum": ["x86_64", "riscv64"] }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kernel", "initrd", "rootfs", "appCompose"],
      "description": "Measured component digests. kernel/initrd/rootfs map to RTMR1/RTMR2/rootfs-hash on TDX; appCompose maps to RTMR3. Each entry's digest is the bytes the substrate folds into a measurement register.",
      "properties": {
        "kernel": { "$ref": "#/$defs/component" },
        "initrd": { "$ref": "#/$defs/component" },
        "rootfs": { "$ref": "#/$defs/component" },
        "appCompose": { "$ref": "#/$defs/component" }
      }
    },
    "buildInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolchain", "layers"],
      "description": "Inputs a verifier needs to recompute the component digests offline.",
      "properties": {
        "toolchain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "sha256"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "repo", "commit"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "repo": { "type": "string", "minLength": 1 },
              "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
            }
          }
        }
      }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boot", "os", "policy", "agent"],
      "description": "Normalized golden measurements derived from components/buildInputs; must agree with the release manifest tee.measurements block.",
      "properties": {
        "boot": { "$ref": "#/$defs/digest" },
        "os": { "$ref": "#/$defs/digest" },
        "policy": { "$ref": "#/$defs/digest" },
        "agent": { "$ref": "#/$defs/digest" },
        "container": { "$ref": "#/$defs/digest" },
        "compose": { "$ref": "#/$defs/digest" },
        "device": { "$ref": "#/$defs/digest" },
        "gpuFirmware": { "$ref": "#/$defs/digest" },
        "npuFirmware": { "$ref": "#/$defs/digest" },
        "modelWeights": { "$ref": "#/$defs/digest" },
        "monitor": { "$ref": "#/$defs/digest" }
      }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmed", "note"],
      "description": "Until a real reproducible build exists (gate OS-5), confirmed is false and the manifest is a fixture validated for schema-conformance + digest shape only.",
      "properties": {
        "confirmed": { "type": "boolean" },
        "reproBuildContext": { "type": ["string", "null"] },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "blockedOn", "provingCommand"],
      "properties": {
        "name": { "const": "confidential-image-manifest-check" },
        "blockedOn": { "type": "string", "minLength": 1 },
        "provingCommand": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "digest", "measuredInto"],
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "measuredInto": { "type": "string", "minLength": 1 }
      }
    }
  }
}
